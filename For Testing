local targetPosition = rootPart.Position
local isResting = false
local restTimer = 0
local currentVisualHeading = rootPart.CFrame.LookVector
local lastVisitedPosition = rootPart.Position

-- Intelligence Combat Parameters
local currentEnemyTarget = nil
local combatRange = 60 -- Maximum entity detection radius (studs)
local lastShootTime = 0
local shootCooldown = 0.5 -- Cooldown firing rate (seconds)

local calculateSmartLurkerPath

-- =========================================================================
-- AUTOMATIC COMBAT ENGINE (WITH LINE OF SIGHT FILTERS)
-- =========================================================================
local function drawLaserBeam(from, to)
	local distance = (from - to).Magnitude
	local laser = Instance.new("Part")
	laser.Name = "GilbertLaserEffect"
	laser.Anchored = true
	laser.CanCollide = false
	laser.Color = Color3.fromRGB(255, 0, 0) -- Bright Red debug laser
	laser.Material = Enum.Material.Neon
	laser.Size = Vector3.new(0.15, 0.15, distance)
	laser.CFrame = CFrame.lookAt(from, to) * CFrame.new(0, 0, -distance / 2)
	laser.Parent = Workspace
	game:GetService("Debris"):AddItem(laser, 0.08) -- Instantly removed from cache
end

-- Optimized Loop: Runs 3 times per second to check Line of Sight without lag
task.spawn(function()
	while true do
		task.wait(0.33)
		if getgenv().LurkerAI_Enabled and character and character:FindFirstChild("HumanoidRootPart") then
			local closestEnemy = nil
			local shortestDistance = combatRange
			local originPoint = rootPart.Position + Vector3.new(0, 0.5, 0) -- Bot's field of view origin
			
			-- Setup physical visibility parameters
			local losParams = RaycastParams.new()
			losParams.FilterType = Enum.RaycastFilterType.Exclude
			
			-- Exclude bot and other online players from blocking the sight raycast
			local ignoreList = {character}
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Character then table.insert(ignoreList, p.Character) end
			end
			losParams.FilterDescendantsInstances = ignoreList
			
			-- Search for valid targets across Workspace
			for _, desc in ipairs(Workspace:GetDescendants()) do
				if desc:IsA("Humanoid") and desc.Parent and desc.Parent ~= character then
					local enemyRoot = desc.Parent:FindFirstChild("HumanoidRootPart") or desc.Parent:FindFirstChild("Torso")
					if enemyRoot and desc.Health > 0 then
						
						-- Rule 1: Must NOT be a real player
						local isAPlayer = Players:GetPlayerFromCharacter(desc.Parent)
						if not isAPlayer then
							local targetPos = enemyRoot.Position
							local dist = (rootPart.Position - targetPos).Magnitude
							
							-- Rule 2: If within distance, execute the Line of Sight check
							if dist < shortestDistance then
								local direction = (targetPos - originPoint)
								local losRay = Workspace:Raycast(originPoint, direction, losParams)
								
								-- Target acquired only if ray is clean or directly intersects the target model
								if not losRay or losRay.Instance:IsDescendantOf(desc.Parent) then
									shortestDistance = dist
									closestEnemy = enemyRoot
								end
							end
						end
					end
				end
			end
			currentEnemyTarget = closestEnemy
		else
			currentEnemyTarget = nil
		end
	end
end)

