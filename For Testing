-- =========================================================================
-- MOTOR DE ANIMACIÓN PROCEDURAL (MATEMÁTICA INTEGRADA)
-- =========================================================================
local function getMotor6D(partName, motorName)
	local p = character:FindFirstChild(partName)
	if p then return p:FindFirstChild(motorName) end
	return nil
end

local function applyProceduralWalk(angleTime, isMovingFlag)
	-- Intentar mapear motores R15 comunes
	local joints = {
		LeftHip = getMotor6D("LeftUpperLeg", "LeftHip") or getMotor6D("Torso", "Left Hip"),
		RightHip = getMotor6D("RightUpperLeg", "RightHip") or getMotor6D("Torso", "Right Hip"),
		LeftShoulder = getMotor6D("LeftUpperArm", "LeftShoulder") or getMotor6D("Torso", "Left Shoulder"),
		RightShoulder = getMotor6D("RightUpperArm", "RightShoulder") or getMotor6D("Torso", "Right Shoulder"),
		LowerTorso = getMotor6D("LowerTorso", "Root") or getMotor6D("HumanoidRootPart", "RootJoint")
	}

	if isMovingFlag then
		-- Frecuencia base multiplicada por la velocidad del menú
		local speedMultiplier = 8 * getgenv().GilbertFootSpeed
		local t = angleTime * speedMultiplier
		
		-- Calcular ondas Seno / Coseno para simular balanceo orgánico
		local limbWave = math.sin(t) * 0.45 
		local bodyBob = math.abs(math.sin(t)) * 0.15 -- El torso baja y sube levemente
		
		-- Aplicar rotaciones angulares cruzadas (brazo izquierdo adelante -> pierna derecha adelante)
		if joints.LeftHip then joints.LeftHip.Transform = CFrame.Angles(limbWave, 0, 0) end
		if joints.RightHip then joints.RightHip.Transform = CFrame.Angles(-limbWave, 0, 0) end
		if joints.LeftShoulder then joints.LeftShoulder.Transform = CFrame.Angles(-limbWave * 0.8, 0, math.rad(-5)) end
		if joints.RightShoulder then joints.RightShoulder.Transform = CFrame.Angles(limbWave * 0.8, 0, math.rad(5)) end
		if joints.LowerTorso then joints.LowerTorso.Transform = CFrame.new(0, -bodyBob, 0) * CFrame.Angles(0, math.sin(t)*0.05, 0) end
	else
		-- Resetear extremidades a posición neutral si se detiene
		for _, joint in pairs(joints) do
			if joint then joint.Transform = CFrame.new() end
		end
	end
end

