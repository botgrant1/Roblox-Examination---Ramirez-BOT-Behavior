-- =========================================================================
-- PATHFINDING RAYCAST MOTORS (PATROL & EMERGENCY ESCAPE)
-- =========================================================================
calculateSmartLurkerPath = function()
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {character}
	local origin = rootPart.Position + Vector3.new(0, 0.5, 0)
	local validOptions = {}
	
	for i = 1, 12 do
		local angle = math.rad(i * 30)
		local direction = Vector3.new(math.cos(angle), 0, math.sin(angle)).Unit
		local ray = Workspace:Raycast(origin, direction * 50, rayParams)
		local dist = ray and (ray.Position - rootPart.Position).Magnitude or 50
		if dist > 15 then table.insert(validOptions, rootPart.Position + direction * (dist - 5)) end
	end
	
	lastVisitedPosition = rootPart.Position
	return #validOptions > 0 and validOptions[math.random(1, #validOptions)] or rootPart.Position
end

calculateEmergencyEscapePath = function(dangerPosition)
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {character}
	
	-- Base escape vector (Perfect opposite direction from danger source)
	local rawEscapeDirection = (Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z) - Vector3.new(dangerPosition.X, 0, dangerPosition.Z)).Unit
	local bestEscapePoint = rootPart.Position + (rawEscapeDirection * 45) -- Target far distance escape
	
	-- Scan alternatives in a 90-degree arc if direct opposite path hits a wall instantly
	local validEscapeRoutes = {}
	for offsetAngle = -45, 45, 15 do
		local rad = math.rad(offsetAngle)
		local rotatedDirection = Vector3.new(
			rawEscapeDirection.X * math.cos(rad) - rawEscapeDirection.Z * math.sin(rad),
			0,
			rawEscapeDirection.X * math.sin(rad) + rawEscapeDirection.Z * math.cos(rad)
		).Unit
		
		local origin = rootPart.Position + Vector3.new(0, 0.5, 0)
		local wallCheck = Workspace:Raycast(origin, rotatedDirection * 45, rayParams)
		local openDistance = wallCheck and (wallCheck.Position - rootPart.Position).Magnitude or 45
		
		if openDistance > 12 then
			table.insert(validEscapeRoutes, {
				point = rootPart.Position + rotatedDirection * (openDistance - 4),
				dist = openDistance
			})
		end
	end
	
	if #validEscapeRoutes > 0 then
		table.sort(validEscapeRoutes, function(a, b) return a.dist > b.dist end) -- Pick the deepest path available
		return validEscapeRoutes[1].point
	end
	
	return bestEscapePoint
end

-- =========================================================================
-- MAIN HEARTBEAT EXECUTION LOOP & TACTICAL SPRINT LOGIC
-- =========================================================================
RunService.Heartbeat:Connect(function(deltaTime)
	if not getgenv().LurkerAI_Enabled or not humanoid or humanoid.Health <= 0 then return end
	
	-- PRIORITY 1: CLOSE COMBAT MELEE ENGAGEMENT
	if currentEnemyTarget and currentEnemyTarget.Parent and currentEnemyTarget.Parent:FindFirstChildOfClass("Humanoid") and currentEnemyTarget.Parent:FindFirstChildOfClass("Humanoid").Health > 0 and not isExecutingHitAndRun then
		local enemyPos = currentEnemyTarget.Position
		local distanceToEnemy = (rootPart.Position - enemyPos).Magnitude
		
		statusLabel.Text = "CLOSING DISTANCE: " .. string.upper(currentEnemyTarget.Parent.Name)
		statusLabel.TextColor3 = Color3.fromRGB(255, 140, 60)
		
		local lookTarget = Vector3.new(enemyPos.X, rootPart.Position.Y, enemyPos.Z)
		rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.lookAt(rootPart.Position, lookTarget), 15 * deltaTime)
		
		if distanceToEnemy > (attackTriggerRange - 2) then
			local moveDir = (Vector3.new(enemyPos.X, 0, enemyPos.Z) - Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)).Unit
			pcall(function() humanoid.RootPart.AssemblyLinearVelocity = moveDir * 9.5 end)
		else
			-- EXECUTING MELEE HIT
			if os.clock() - lastMeleeStrikeTime >= meleeCooldown then
				lastMeleeStrikeTime = os.clock()
				isExecutingHitAndRun = true
				
				statusLabel.Text = "MELEE STRIKE REGISTERED! [G]"
				statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
				pcall(function() humanoid.RootPart.AssemblyLinearVelocity = Vector3.new() end)
				
				-- Fire native Keyboard Signal G
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.G, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.G, false, game)
				
				-- INITIALIZE EMERGENCY SPRINT ESCAPE ROUTINE
				task.spawn(function()
					currentEnemyTarget = nil
					targetPosition = calculateEmergencyEscapePath(enemyPos)
					
					statusLabel.Text = "TACTICAL ESCAPE ACTIVE [SHIFT]"
					statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
					
					-- Press Left Shift to activate game sprint script mechanics
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.LeftShift, false, game)
					
					task.wait(1.4) -- Duration of the forced uninterruptible sprint away
					
					-- Release Left Shift to go back to regular step speed
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftShift, false, game)
					isExecutingHitAndRun = false
					isResting = false
					targetPosition = calculateSmartLurkerPath() -- Recalculate normal patrol
				end)
			end
		end
		return
	end
	
	-- PRIORITY 2: EMERGENCY ESCAPE TRANS-LOCATION (TACTICAL SPRINT ACTIVE)
	if isExecutingHitAndRun then 
		local flatChar = Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)
		local flatTarget = Vector3.new(targetPosition.X, 0, targetPosition.Z)
		local moveDirection = (flatTarget - flatChar).Unit
		
		local sprintVelocitySpeed = 16.0 -- Fast tactical sprint velocity value
		pcall(function() humanoid.RootPart.AssemblyLinearVelocity = moveDirection * sprintVelocitySpeed end)
		
		currentVisualHeading = currentVisualHeading:Lerp(moveDirection, 16 * deltaTime).Unit
		rootPart.CFrame = CFrame.lookAt(rootPart.Position + moveDirection * (sprintVelocitySpeed * deltaTime), rootPart.Position + currentVisualHeading)
		return 
	end

	-- PRIORITY 3: STANDARD CORRIDOR PROWLING PATROL
	local currentSpeed = 7.2
	local moveDirection = Vector3.new()
	local isCurrentlyMoving = false
	
	if isResting then
		restTimer = restTimer - deltaTime
		statusLabel.Text = "Prowling Pause: " .. string.format("%.1f", restTimer) .. "s"
		statusLabel.TextColor3 = Color3.fromRGB(240, 200, 80)
		if restTimer <= 0 then
			isResting = false
			targetPosition = calculateSmartLurkerPath()
		end
		pcall(function() humanoid.RootPart.AssemblyLinearVelocity = Vector3.new() end)
		return
	end
	
	local flatChar = Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)
	local flatTarget = Vector3.new(targetPosition.X, 0, targetPosition.Z)
	local distance = (flatChar - flatTarget).Magnitude
	
	if distance > 3.5 then
		moveDirection = (flatTarget - flatChar).Unit
		isCurrentlyMoving = true
		statusLabel.Text = "Sweeping Corridors..."
		statusLabel.TextColor3 = Color3.fromRGB(100, 200, 100)
	else
		isResting = true
		restTimer = math.random(15, 50) / 10
		return
	end
	
	-- Apply regular patrol physics
	if isCurrentlyMoving and moveDirection.Magnitude > 0 then
		local nextPosition = rootPart.Position + moveDirection * (currentSpeed * deltaTime)
		currentVisualHeading = currentVisualHeading:Lerp(moveDirection, 14 * deltaTime).Unit
		rootPart.CFrame = CFrame.lookAt(nextPosition, rootPart.Position + currentVisualHeading)
		
		pcall(function() humanoid.RootPart.AssemblyLinearVelocity = moveDirection * currentSpeed end)
		
		local animator = humanoid:FindFirstChildOfClass("Animator")
		if animator then
			for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
				if track.Name == "WalkAnim" or track.Name == "RunAnim" or string.find(string.lower(track.Name), "walk") or string.find(string.lower(track.Name), "run") then
					track:AdjustSpeed(getgenv().GilbertFootSpeed)
				end
			end
		end
	end
end)

