-- EXPERIMENTO FE: Ocultar NameTag moviendo la cabeza (Requiere replicación libre)
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer
local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()

local head = char:WaitForChild("Head", 5)
local torso = char:WaitForChild("Torso", 5) or char:WaitForChild("UpperTorso", 5) -- Compatible con R6 y R15

if head and torso then
	-- STEP 1: Asegurar accesorios locales al Torso para mantener la estética
	for _, instance in ipairs(char:GetChildren()) do
		if instance:IsA("Accessory") and instance:FindFirstChild("Handle") then
			local handle = instance.Handle
			
			-- Limpiamos uniones viejas con la cabeza
			for _, joint in ipairs(handle:GetChildren()) do
				if joint:IsA("Weld") or joint:IsA("WeldConstraint") or joint:IsA("Attachment") then
					joint:Destroy()
				end
			end
			
			-- Creamos la nueva unión fija directo al pecho/torso
			local newWeld = Instance.new("WeldConstraint")
			newWeld.Part0 = handle
			newWeld.Part1 = torso
			newWeld.Parent = handle
			handle.CanCollide = false
		end
	end
	
	-- STEP 2: Romper la unión del cuello para liberar la cabeza de las animaciones del servidor
	local neck = head:FindFirstChild("Neck") or torso:FindFirstChild("Neck")
	if neck then
		neck:Destroy()
	end
	
	-- STEP 3: Forzar la replicación enviando la cabeza al vacío
	-- Usamos Heartbeat para asegurar que la física local obligue al servidor a registrar la nueva posición
	game:GetService("RunService").Heartbeat:Connect(function()
		if head and head.Parent then
			-- Desplazamos la cabeza 500 studs hacia abajo de tu posición actual
			head.CFrame = torso.CFrame * CFrame.new(0, -500, 0)
			head.AssemblyLinearVelocity = Vector3.new(0, -100, 0) -- Fuerza física extra para asegurar réplica
		end
	end)
end
