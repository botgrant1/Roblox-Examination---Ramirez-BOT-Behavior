-- CONFIGURACIÓN DE PARÁMETROS DEL BOT
local BotSettings = {
	PatrolNodes = {},        
	AcceptanceRadius = 4,    
	ViewDistance = 60,       
	FieldOfView = 90,        
	CheckRate = 0.1,         
}

-- ENCONTRAR INSTANCIAS (Se buscan dinámicamente si el bot spawnea)
local botCharacter = script.Parent
local botHead = botCharacter:WaitForChild("Head", 5)
local botTorso = botCharacter:FindFirstChild("Torso") or botCharacter:FindFirstChild("UpperTorso")
local botHumanoid = botCharacter:WaitForChild("Humanoid", 5)

-- VARIABLES DE ESTADO GLOBALES (Accesibles por el Menú)
getgenv().BotMaster_SystemActive = false
getgenv().BotMaster_VisualActive = false

local BotStates = { PATROL = "Patrol", CHASE = "Chase" }
local currentBotState = BotStates.PATROL
local currentNodeIndex = 1
local currentTarget = nil

