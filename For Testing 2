local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local head = character:WaitForChild("Head", 5)
local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")

getgenv().FENameTag_Enabled = false
local heartbeatConnection = nil
local originalHeadSize = Vector3.new(1, 1, 1)
local originalAttachments = {}

if localPlayer:WaitForChild("PlayerGui"):FindFirstChild("TagControlGui") then
	localPlayer.PlayerGui.TagControlGui:Destroy()
end

local function applyFEScaleCero()
	character = localPlayer.Character
	if not character then return end
	head = character:FindFirstChild("Head")
	torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
	
	if head and torso then
		originalHeadSize = head.Size
		table.clear(originalAttachments)
		
		-- 1. Redireccionar Attachments de la Cabeza al Torso de forma relativa
		for _, instance in ipairs(character:GetChildren()) do
			if instance:IsA("Accessory") and instance:FindFirstChild("Handle") then
				local handle = instance.Handle
				local accAnc = handle:FindFirstChildOfClass("Attachment")
				
				if accAnc then
					-- Buscamos el attachment correspondiente en la cabeza
					local headAnc = head:FindFirstChild(accAnc.Name)
					if headAnc then
						-- Guardamos su posición original por si desactivamos el script
						originalAttachments[accAnc] = headAnc.Parent
						
						-- Movemos el punto de unión de la cabeza directo al Torso, 
						-- pero compensamos la altura (+1.5 studs aprox) para que flote sobre tus hombros
						headAnc.Parent = torso
						headAnc.CFrame = CFrame.new(0, 1.5, 0) 
					end
				end
			end
		end
		
		-- 2. Achicar la cabeza a nivel microscópico para romper el NameTag
		head.Size = Vector3.new(0.01, 0.01, 0.01)
		local mesh = head:FindFirstChildOfClass("SpecialMesh")
		if mesh then
			mesh.Scale = Vector3.new(0, 0, 0)
		end
		
		-- 3. Persistencia anti-animación
		if heartbeatConnection then heartbeatConnection:Disconnect() end
		heartbeatConnection = RunService.Heartbeat:Connect(function()
			if head and head.Parent and getgenv().FENameTag_Enabled then
				head.Size = Vector3.new(0.01, 0.01, 0.01)
			end
		end)
	end
end

local function restoreCharacterNormality()
	if heartbeatConnection then 
		heartbeatConnection:Disconnect() 
		heartbeatConnection = nil
	end
	
	character = localPlayer.Character
	if not character then return end
	head = character:FindFirstChild("Head")
	torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
	
	if head and torso then
		head.Size = originalHeadSize
		local mesh = head:FindFirstChildOfClass("SpecialMesh")
		if mesh then
			mesh.Scale = Vector3.new(1, 1, 1)
		end
		
		-- Restaurar attachments a la cabeza original
		for accAnc, originalParent in pairs(originalAttachments) do
			if accAnc and originalParent then
				local headAnc = torso:FindFirstChild(accAnc.Name)
				if headAnc then
					headAnc.Parent = head
					headAnc.CFrame = CFrame.new(0, 0, 0) -- Reseteo a posición base de Roblox
				end
			end
		end
	end
end

