-- EXPERIMENTO FE V3: Escala Cero (Sin romper colisiones ni articulaciones)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local head = char:WaitForChild("Head", 5)
local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
local humanoid = char:WaitForChild("Humanoid", 5)

if head and torso and humanoid then
	-- STEP 1: Asegurar accesorios locales al Torso (Evita que se encojan con la cabeza)
	for _, instance in ipairs(char:GetChildren()) do
		if instance:IsA("Accessory") and instance:FindFirstChild("Handle") then
			local handle = instance.Handle
			
			for _, joint in ipairs(handle:GetChildren()) do
				if joint:IsA("Weld") or joint:IsA("WeldConstraint") or joint:IsA("Attachment") then
					joint:Destroy()
				end
			end
			
			local newWeld = Instance.new("WeldConstraint")
			newWeld.Part0 = handle
			newWeld.Part1 = torso
			newWeld.Parent = handle
			handle.CanCollide = false
		end
	end
	
	-- STEP 2: Encojer la cabeza de forma replicada
	-- Al cambiar el Size a algo diminuto, el NameTag se cansa de calcular el tamaño y desaparece (FE)
	head.Size = Vector3.new(0.01, 0.01, 0.01)
	
	-- Si tiene un SpecialMesh interno, también lo hacemos microscópico
	local mesh = head:FindFirstChildOfClass("SpecialMesh")
	if mesh then
		mesh.Scale = Vector3.new(0, 0, 0)
	end
	
	-- Forzamos a que conserve el tamaño por si el script de animaciones intenta inflarla de nuevo
	RunService.Heartbeat:Connect(function()
		if head and head.Parent then
			head.Size = Vector3.new(0.01, 0.01, 0.01)
		end
	end)
end
